<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/waiting_bg"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/topButtonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/createRoomButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_primary"
            android:text="@string/lobby_list_create"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/refreshButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_secondary"
            android:text="@string/lobby_list_refresh"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/backToTitleButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action_secondary"
            android:text="@string/lobby_list_back_title"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/codeJoinRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topButtonRow">

        <EditText
            android:id="@+id/roomCodeInput"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_panel_waiting"
            android:hint="@string/lobby_list_code_hint"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textColor="@color/waiting_text_primary"
            android:textColorHint="@color/waiting_text_secondary"
            android:textSize="14sp" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/joinByCodeButton"
            android:layout_width="90dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_action_primary"
            android:text="@string/lobby_list_join_code"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/roomPasswordInput"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_panel_waiting"
        android:hint="@string/lobby_list_password_hint"
        android:inputType="textPassword"
        android:paddingHorizontal="12dp"
        android:singleLine="true"
        android:textColor="@color/waiting_text_primary"
        android:textColorHint="@color/waiting_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/codeJoinRow" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/roomRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/roomPasswordInput" />

</androidx.constraintlayout.widget.ConstraintLayout>
