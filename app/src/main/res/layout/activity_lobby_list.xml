<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/waiting_bg"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/topButtonRow"
        android:layout_width="220dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_panel_waiting"
        android:elevation="2dp"
        android:gravity="top"
        android:orientation="vertical"
        android:padding="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/lobbyListTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="@string/lobby_list_title"
            android:textColor="@color/waiting_text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lobbyListSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/lobby_list_subtitle"
            android:textColor="@color/waiting_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createRoomButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:elevation="3dp"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/lobby_list_create"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/primary"
            app:autoSizeMaxTextSize="14sp"
            app:autoSizeMinTextSize="11sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_add_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp"
            app:iconTint="@android:color/white"
            app:rippleColor="@color/primary_dark" />

        <Space
            android:layout_width="1dp"
            android:layout_height="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/joinByCodeButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:elevation="3dp"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/lobby_list_join_code"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/primary"
            app:autoSizeMaxTextSize="14sp"
            app:autoSizeMinTextSize="11sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_key_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp"
            app:iconTint="@android:color/white"
            app:rippleColor="@color/primary_dark" />

        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backToTitleButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:elevation="1dp"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/lobby_list_back_title"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:backgroundTint="#64748B"
            app:autoSizeMaxTextSize="14sp"
            app:autoSizeMinTextSize="11sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_close_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp"
            app:iconTint="@android:color/white"
            app:rippleColor="#475569" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/roomRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/topButtonRow"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/emptyLobbyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="@string/lobby_list_empty"
        android:textColor="@color/waiting_text_secondary"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/roomRecyclerView"
        app:layout_constraintEnd_toEndOf="@id/roomRecyclerView"
        app:layout_constraintStart_toStartOf="@id/roomRecyclerView"
        app:layout_constraintTop_toTopOf="@id/roomRecyclerView" />

</androidx.constraintlayout.widget.ConstraintLayout>
