<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#404040">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutDiceMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        android:clipChildren="false">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintHeight_percent="0.9"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:clipChildren="false">

                <TextView
                    android:id="@+id/txtTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textSize="50sp"
                    android:textColor="#FFCA28"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/txtInstruction"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/txtInstruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주사위 버튼을 선택하고 굴리기를 누르세요"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/txtTimer"
                    app:layout_constraintBottom_toTopOf="@id/txtDiceVisual"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/txtDiceVisual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚀"
                    android:textSize="80sp"
                    android:textColor="#333333"
                    android:layout_marginTop="-6dp"
                    app:layout_constraintTop_toBottomOf="@id/txtInstruction"
                    app:layout_constraintBottom_toTopOf="@id/diceContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <FrameLayout
                    android:id="@+id/diceContainer"
                    android:layout_width="500dp"
                    android:layout_height="70dp"
                    android:layout_marginTop="-10dp"
                    android:clipChildren="false"
                    app:layout_constraintTop_toBottomOf="@id/txtDiceVisual"
                    app:layout_constraintBottom_toTopOf="@id/btnRoll"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <Button
                        android:id="@+id/btnDice12"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:text="1~2\n(30%)"
                        android:backgroundTint="#42A5F5"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnDice34"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:layout_marginStart="133dp"
                        android:text="3~4\n(20%)"
                        android:backgroundTint="#66BB6A"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnDice56"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:layout_marginStart="266dp"
                        android:text="5~6\n(20%)"
                        android:backgroundTint="#FFA726"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnDiceRandom"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:layout_marginStart="400dp"
                        android:text="랜덤\n(1/6)"
                        android:backgroundTint="#AB47BC"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <Button
                    android:id="@+id/btnRoll"
                    android:layout_width="200dp"
                    android:layout_height="60dp"
                    android:text="굴리기"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1976D2"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/diceContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardResultPopup"
        android:layout_width="400dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        app:cardCornerRadius="16dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="주사위 결과"
                android:textSize="24sp"
                android:textColor="#757575"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtFinalDiceResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="80sp"
                android:textColor="#1976D2"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>