<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/title_bg_pastel"
    android:paddingHorizontal="32dp"
    android:paddingVertical="22dp">

    <TextView
        android:id="@+id/nicknameBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_title_nickname_badge"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp"
        android:textColor="@color/title_badge_text"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_screen_title"
        android:includeFontPadding="false"
        android:textColor="@color/title_text_green"
        android:textSize="42sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/joinGameButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/joinGameButton"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="12dp"
        android:elevation="4dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingHorizontal="12dp"
        android:text="@string/title_join_button"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="15sp"
        app:autoSizeMaxTextSize="24sp"
        app:autoSizeStepGranularity="1sp"
        app:backgroundTint="@color/title_blue"
        app:cornerRadius="8dp"
        app:icon="@drawable/ic_login_24"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconSize="24dp"
        app:iconTint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/optionsButton"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:rippleColor="@color/title_blue_pressed" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/optionsButton"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:layout_marginStart="12dp"
        android:elevation="3dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingHorizontal="12dp"
        android:text="@string/title_options_button"
        android:textAllCaps="false"
        android:textColor="#1E1E1E"
        android:textSize="24sp"
        android:textStyle="bold"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="15sp"
        app:autoSizeMaxTextSize="24sp"
        app:autoSizeStepGranularity="1sp"
        app:backgroundTint="@color/title_yellow"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/joinGameButton"
        app:layout_constraintTop_toTopOf="@id/joinGameButton"
        app:rippleColor="@color/title_yellow_pressed" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/rulesButton"
        android:layout_width="300dp"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:elevation="2dp"
        android:includeFontPadding="false"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingHorizontal="14dp"
        android:text="@string/title_rules_button"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="#64748B"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/joinGameButton"
        app:rippleColor="#475569" />

</androidx.constraintlayout.widget.ConstraintLayout>
