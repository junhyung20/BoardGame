<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/layoutExplanation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="#1E1E1E"
        android:visibility="visible">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="미니게임 2\n비밀번호 설정" android:textSize="28sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginBottom="24dp" android:gravity="center"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="숨겨진 조건들을 모두 만족하는\n비밀번호를 입력하세요!\n\n스테이지가 오를수록\n조건이 까다로워집니다.\n\n⚠️ 스마트폰을 세로로 돌려주세요!" android:textSize="18sp" android:textColor="#B0BEC5" android:lineSpacingExtra="8dp" android:gravity="center" android:layout_marginBottom="40dp"/>
        <TextView android:id="@+id/explanationTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10" android:textSize="48sp" android:textColor="#FFCA28" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutCountdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone">
        <TextView android:id="@+id/countdownText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textSize="120sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutGame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">
        <TextView android:id="@+id/stageTitleText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="STAGE 1" android:textSize="24sp" android:textStyle="bold" android:gravity="center" android:textColor="#1976D2" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/timerText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="남은 시간: 00:30" android:textSize="32sp" android:textStyle="bold" android:gravity="center" android:textColor="#D32F2F" android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:elevation="4dp" android:layout_marginBottom="20dp">
            <TextView android:id="@+id/rule1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="조건 1: ???" android:textSize="18sp" android:layout_marginBottom="12dp" android:visibility="gone"/>
            <TextView android:id="@+id/rule2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="조건 2: ???" android:textSize="18sp" android:layout_marginBottom="12dp" android:visibility="gone"/>
            <TextView android:id="@+id/rule3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="조건 3: ???" android:textSize="18sp" android:layout_marginBottom="12dp" android:visibility="gone"/>
            <TextView android:id="@+id/rule4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="조건 4: ???" android:textSize="18sp" android:layout_marginBottom="12dp" android:visibility="gone"/>
            <TextView android:id="@+id/rule5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="조건 5: ???" android:textSize="18sp" android:visibility="gone"/>
        </LinearLayout>

        <EditText android:id="@+id/passwordInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="비밀번호 입력" android:inputType="textVisiblePassword" android:textSize="20sp" android:padding="16dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>
        <TextView android:id="@+id/clearText" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textSize="18sp" android:gravity="center" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutStageResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#263238"
        android:padding="24dp"
        android:visibility="gone">
        <TextView android:id="@+id/stageResultStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1스테이지 통과!" android:textSize="36sp" android:textColor="#4CAF50" android:textStyle="bold" android:layout_marginBottom="30dp"/>
        <TextView android:id="@+id/stageRankText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="현재 등수: 1등" android:textSize="24sp" android:textColor="#FFFFFF" android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/stageScoreText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="획득 점수: +100점" android:textSize="24sp" android:textColor="#FFCA28" android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/totalScoreText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="누적 점수: 100점" android:textSize="28sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginBottom="40dp"/>
        <TextView android:id="@+id/nextStageNoticeText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="잠시 후 다음 스테이지가 시작됩니다..." android:textSize="16sp" android:textColor="#90A4AE"/>
    </LinearLayout>

</FrameLayout>