<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    android:layout_margin="6dp"
    android:background="@drawable/bg_room_item"
    android:elevation="1dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/roomItemCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:textColor="@color/primary_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/roomItemHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:textColor="@color/waiting_text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/roomItemCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:includeFontPadding="false"
            android:textColor="@color/primary_light"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/roomItemJoin"
        android:layout_width="84dp"
        android:layout_height="38dp"
        android:layout_marginStart="8dp"
        android:elevation="1dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingHorizontal="10dp"
        android:singleLine="true"
        android:text="@string/lobby_room_join"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        app:cornerRadius="8dp"
        app:icon="@drawable/ic_login_24"
        app:iconGravity="textStart"
        app:iconPadding="4dp"
        app:iconSize="16dp"
        app:iconTint="@android:color/white"
        app:rippleColor="@color/primary_dark" />

</LinearLayout>
