<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="104dp"
    android:layout_margin="6dp"
    android:background="@drawable/bg_room_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/roomItemCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/waiting_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/roomItemHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/waiting_text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/roomItemCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/primary_light"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/roomItemJoin"
        android:layout_width="76dp"
        android:layout_height="34dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_action_primary"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:text="@string/lobby_room_join"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
