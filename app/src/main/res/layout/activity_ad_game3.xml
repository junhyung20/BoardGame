<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#404040"
    tools:ignore="HardcodedText,ContentDescription">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutAdContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:id="@+id/mainAdCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintHeight_percent="0.9"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtInstruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="카운트를 채워 광고를 제거하세요"
                    android:textSize="30sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/stopwatchText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00.00"
                    android:textSize="40sp"
                    android:textColor="#FFCA28"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/txtInstruction"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/clickCounterText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="카운트 0 / 30"
                    android:textSize="28sp"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/stopwatchText"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <FrameLayout
                    android:id="@+id/clickGaugeContainer"
                    android:layout_width="0dp"
                    android:layout_height="12dp"
                    android:background="#E0E0E0"
                    android:layout_marginTop="8dp"
                    app:layout_constraintWidth_percent="0.6"
                    app:layout_constraintTop_toBottomOf="@id/clickCounterText"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:id="@+id/clickGaugeFill"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1976D2"
                        android:scaleX="0.0" />
                </FrameLayout>

                <TextView
                    android:id="@+id/txtAdRemovalTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="광고 제거"
                    android:textSize="20sp"
                    android:textColor="#757575"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/clickGaugeContainer"
                    app:layout_constraintTop_toTopOf="@id/clickGaugeContainer"
                    app:layout_constraintBottom_toBottomOf="@id/clickGaugeContainer" />

                <Button
                    android:id="@+id/btnTap"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:text="TAP!\n(+1)"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="75dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/clickGaugeContainer"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutCountdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:elevation="100dp"
        android:translationZ="100dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="광고를 제거하세요"
            android:textSize="36sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/countdownText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textSize="120sp"
            android:textColor="#FFCA28"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardAdResultPopup"
        android:layout_width="500dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        app:cardCornerRadius="16dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/adResultStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="광고 제거 성공!"
                android:textSize="32sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:gravity="center" />

            <TextView
                android:id="@+id/adResultScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="획득 점수: +50점"
                android:textSize="20sp"
                android:textColor="#FFCA28"
                android:gravity="center" />

            <TextView
                android:id="@+id/adResultClicks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최종 터치: 35회"
                android:textSize="16sp"
                android:textColor="#757575"
                android:layout_marginTop="8dp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5초 뒤 메인 보드판으로 돌아갑니다..."
                android:textSize="14sp"
                android:textColor="#90A4AE"
                android:layout_marginTop="20dp"
                android:gravity="center" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>