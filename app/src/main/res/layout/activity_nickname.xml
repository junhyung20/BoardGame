<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/waiting_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/nicknameTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/nickname_title"
        android:textColor="@color/waiting_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/nicknameGuide"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/nickname_guide"
        android:textColor="@color/waiting_text_secondary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nicknameTitle" />

    <EditText
        android:id="@+id/nicknameInput"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_panel_waiting"
        android:hint="@string/nickname_hint"
        android:inputType="textPersonName"
        android:maxLength="12"
        android:paddingHorizontal="16dp"
        android:textColor="@color/waiting_text_primary"
        android:textColorHint="@color/waiting_text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nicknameGuide" />

    <Button
        android:id="@+id/saveNicknameButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_action_primary"
        android:text="@string/nickname_save_button"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="17sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nicknameInput" />

</androidx.constraintlayout.widget.ConstraintLayout>
