<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#404040"
    tools:ignore="HardcodedText,ContentDescription">

    <LinearLayout
        android:id="@+id/layoutCountdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFFFFF"
        android:elevation="100dp"
        android:translationZ="100dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="광고를 제거하세요"
            android:textSize="36sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>
        <TextView
            android:id="@+id/countdownText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textSize="120sp"
            android:textColor="#FFCA28"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutAdContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:id="@+id/mainAdCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintWidth_percent="0.85"
            app:layout_constraintHeight_percent="0.75"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <TextView
                    android:id="@+id/fakeButton2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="닫기"
                    android:textSize="18sp"
                    android:textColor="#9E9E9E"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <ImageView
                    android:id="@+id/fakeButton3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#BDBDBD"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guidelineCenter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.55" />

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/ad_preview"
                    android:scaleType="fitCenter"
                    android:background="#F5F5F5"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintTop_toBottomOf="@id/fakeButton2"
                    app:layout_constraintBottom_toTopOf="@+id/fakeButton4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/guidelineCenter" />

                <TextView
                    android:id="@+id/fakeButton4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skip Ad >>"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toBottomOf="@id/fakeButton3"
                    app:layout_constraintBottom_toTopOf="@+id/fakeButton5"
                    app:layout_constraintStart_toEndOf="@id/guidelineCenter"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E0E0E0">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/bg_bulpyeon"
                                android:scaleType="centerCrop"/>
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="불편마불"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#212121" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Team 7"
                                    android:textSize="16sp"
                                    android:textColor="#757575" />
                                <ImageButton
                                    android:id="@+id/realButton"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:alpha="0.0"
                                    android:layout_marginStart="8dp"
                                    android:background="@android:color/transparent"
                                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                                    app:tint="#CCCCCC" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnInstall"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="설치하기"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:backgroundTint="#2E7D32"
                        android:layout_marginTop="30dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/fakeButton5"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#E0E0E0"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/topTimerPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="36dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp">
                <TextView
                    android:id="@+id/adTimerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10초 남았습니다"
                    android:textSize="16sp"
                    android:textColor="#333333" />
                <ImageView
                    android:id="@+id/fakeButton1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#666666" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardAdResultPopup"
        android:layout_width="600dp"
        android:layout_height="350dp"
        android:layout_gravity="center"
        app:cardCornerRadius="16dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#FFFFFF"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">
            <TextView
                android:id="@+id/adResultStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="광고 제거 성공!"
                android:textSize="36sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:gravity="center"/>
            <TextView
                android:id="@+id/adResultScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="획득 점수: +5점"
                android:textSize="24sp"
                android:textColor="#FFCA28"
                android:gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5초 뒤 메인 보드판으로 돌아갑니다..."
                android:textSize="18sp"
                android:textColor="#90A4AE"
                android:layout_marginTop="30dp"
                android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>