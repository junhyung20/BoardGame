<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#EAF1FB" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#C4D4EA" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/waiting_panel_bg" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="@color/waiting_panel_stroke" />
        </shape>
    </item>
</selector>
