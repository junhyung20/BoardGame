<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.BoardGame">
        <activity
            android:name=".BoardActivity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".DiceActivity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".AdGame1Activity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".AdGame2Activity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".AdGame3Activity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".CaptchaActivity"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name=".PasswordActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false" />
        <activity
            android:name=".VolumeMazeActivity"
            android:screenOrientation="portrait"
            android:exported="false" />
        <activity
            android:name=".LobbyActivity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".LobbyListActivity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".OptionsActivity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".NicknameActivity"
            android:screenOrientation="landscape"
            android:exported="false" />
        <activity
            android:name=".TitleActivity"
            android:screenOrientation="landscape"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
